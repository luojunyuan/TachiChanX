<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="TouchChanX.WinUI.Touch.TouchControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:c="using:TouchChanX.WinUI.Controls"
    xmlns:local="using:TouchChanX.WinUI.Touch"
    xmlns:top="using:TouchChanX.WinUI"
    d:DataContext="{d:DesignInstance Type=local:TouchControl}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AssistiveTouchBackground" Color="#2A2A2A" />
    </UserControl.Resources>

    <Border x:Name="TouchBorder"
        Width="{x:Bind top:Shared.TouchSize}"
        Height="{x:Bind top:Shared.TouchSize}"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Background="{StaticResource AssistiveTouchBackground}"
        CornerRadius="{x:Bind top:Converters.CircleCornerRadius(top:Shared.TouchSize)}"
        ManipulationMode="TranslateX, TranslateY">
        <c:TouchGlyph Width="{x:Bind top:Shared.TouchSize}" />

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="OpacityStates">
                <VisualState x:Name="Normal">
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetName="TouchBorder"
                            Storyboard.TargetProperty="Opacity"
                            To="1.0"
                            Duration="0:0:0.1" />
                    </Storyboard>
                </VisualState>

                <VisualState x:Name="Faded">
                    <Storyboard>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TouchBorder" Storyboard.TargetProperty="Opacity">
                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                            <DiscreteDoubleKeyFrame KeyTime="0:0:4" Value="1.0" />
                            <LinearDoubleKeyFrame KeyTime="0:0:4.4" Value="0.4" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Border>
</UserControl>
