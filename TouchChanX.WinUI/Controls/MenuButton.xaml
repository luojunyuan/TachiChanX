<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="TouchChanX.WinUI.Controls.MenuButton" x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TouchChanX.WinUI.Controls"
    d:DataContext="{d:DesignInstance Type=local:MenuButton}"
    Foreground="White"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#6FC4F1" />
    </UserControl.Resources>

    <Grid Background="Transparent">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
            <SymbolIcon Symbol="{x:Bind Symbol}" />
            <TextBlock HorizontalAlignment="Center" Text="{x:Bind Text}" />
        </StackPanel>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="PressStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="Pressed">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Foreground">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource AccentBrush}" />
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
